pipeline {
    agent any
    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/Arka-1234/ansible-jenkins-lab.git'
            }
        }
        stage('Run Ansible Playbook') {
            steps {
                sh 'ansible-playbook -i hosts install_apache.yml'
            }
        }
    }
}
